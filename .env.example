# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
HOST=0.0.0.0
PORT=1337

# Public URL of this backend (used in PayU success/failure callbacks).
# Local dev with ngrok: set the ngrok https URL here and update on every restart.
BACKEND_URL=http://localhost:1337
# Public URL of the React frontend (used for post-payment redirects).
FRONTEND_URL=http://localhost:5173
# Comma-separated list of origins allowed by CORS in production.
CORS_ORIGINS=http://localhost:5173

# ─────────────────────────────────────────────
# Secrets — generate strong unique values for production
# ─────────────────────────────────────────────
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# ─────────────────────────────────────────────
# Database — PostgreSQL
# ─────────────────────────────────────────────
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=khaki_tours
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=change_me
DATABASE_SSL=false
DATABASE_SCHEMA=public
# Connection pool — raise max for higher concurrency.
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT=60000

# ─────────────────────────────────────────────
# PayU — Group tours + Public WALKS (original gateway)
# ─────────────────────────────────────────────
PAYU_KEY=
PAYU_SALT=
PAYU_BASE_URL=https://test.payu.in/_payment

# ─────────────────────────────────────────────
# PayU — Public EVENTS (separate merchant account)
# Used only by /api/event-payment/* (public event bookings).
# ─────────────────────────────────────────────
EVENT_PAYU_KEY=
EVENT_PAYU_SALT=

# ─────────────────────────────────────────────
# PayU — Donations (separate merchant account)
# ─────────────────────────────────────────────
DONATION_PAYU_KEY=
DONATION_PAYU_SALT=

# ─────────────────────────────────────────────
# Confirmation emails — TWO Gmail/SMTP sender accounts
#   khakitours → Group Tour / Private Tour / Public Walk
#   khakilab   → all forms + Public Events (also Strapi admin emails)
# Use Gmail "App Passwords", not the account password.
# ─────────────────────────────────────────────
KHAKITOURS_EMAIL_USER=hi@khakitours.com
KHAKITOURS_EMAIL_PASS=
KHAKILAB_EMAIL_USER=khakilabevents@gmail.com
KHAKILAB_EMAIL_PASS=
# Optional SMTP overrides (default smtp.gmail.com:587)
# KHAKITOURS_EMAIL_HOST=smtp.gmail.com
# KHAKITOURS_EMAIL_PORT=587
# KHAKILAB_EMAIL_HOST=smtp.gmail.com
# KHAKILAB_EMAIL_PORT=587

# Admin BCC copies — separate address per account.
# khakitours emails (group/private/walk) BCC → KHAKITOURS_BCC
# khakilab emails (forms/events) BCC → KHAKILAB_BCC
KHAKITOURS_BCC=
KHAKILAB_BCC=

# Online-event (talk) Zoom details (optional — template has defaults)
# EVENT_ZOOM_LINK=
# EVENT_ZOOM_MEETING_ID=
# EVENT_ZOOM_PASSCODE=

# Secret for the custom CSV report export endpoint (/api/reports/bookings?token=...)
EXPORT_TOKEN=

# ─────────────────────────────────────────────
# Cloudinary — media storage (persistent across deploys)
# Get these from your Cloudinary dashboard. Leave empty to use local uploads.
# ─────────────────────────────────────────────
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=
